# Bitget API Credentials
BITGET_API_KEY=your_api_key_here
BITGET_API_SECRET=your_api_secret_here
BITGET_API_PASSPHRASE=your_api_passphrase_here

# Bitget Demo API (Optional)
BITGET_DEMO_API_KEY=
BITGET_DEMO_API_SECRET=
BITGET_DEMO_API_PASSPHRASE=

# Strategy/Global Settings
SYMBOL=XAUUSDT
PRODUCT_TYPE=USDT-M
MARGIN_COIN=USDT
LEVERAGE=20

# Position Sizing
POSITION_FRACTION=0.3 # Use 0.3 for 30% margin of balance
RISK_PER_TRADE=0.02 # Original risk setting (Currently inactive)

# Risk Management
DAILY_LOSS_LIMIT=0.05
CONSECUTIVE_LOSS_LIMIT=5
EMERGENCY_STOP_LOSS_ENABLED=True
EMERGENCY_STOP_LOSS_THRESHOLD=0.05

# Slippage Settings
SLIPPAGE_BPS=5

# Optimizer Coefficients
OPTIMIZER_ALPHA=1.0
OPTIMIZER_BETA=0.1
OPTIMIZER_GAMMA=0.5

# Notifications (Optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
PUSHBULLET_API_KEY=your_pushbullet_api_key_here
NGROK_AUTH_TOKEN=your_ngrok_token_here

# Runtime Mode
# paper / backtest / live / optimize / walkforward / backfill
RUN_MODE=backtest
LOG_LEVEL=INFO
